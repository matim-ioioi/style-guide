{
  "name": "@timmio/style-guide",
  "version": "2.0.2",
  "description": "Style guide tools (ESLint 9, Prettier, Stylelint) for web applications",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matim-ioioi/style-guide.git"
  },
  "keywords": [
    "eslint",
    "prettier",
    "stylelint",
    "typescript",
    "vue",
    "graphql",
    "style guide"
  ],
  "author": "Tim Mavrin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/matim-ioioi/style-guide/issues"
  },
  "homepage": "https://github.com/matim-ioioi/style-guide#readme",
  "type": "module",
  "exports": {
    "./eslint": "./dist/eslint/index.js",
    "./prettier": "./src/prettier/index.js",
    "./stylelint": "./src/stylelint/index.js",
    "./*": "./*"
  },
  "files": [
    "dist/",
    "src/prettier/",
    "src/stylelint/"
  ],
  "scripts": {
    "prepare": "husky install",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "eslint": "eslint . --no-config-lookup --config eslint.config.ts",
    "eslint:fix": "npm run eslint -- --fix",
    "tslint": "tsc --noEmit --skipLibCheck",
    "lint": "npm run eslint && npm run tslint",
    "lint:fix": "npm run eslint:fix && npm run tslint",
    "build:clean": "rm -rf dist",
    "build:types": "tsc --project tsconfig.build.json",
    "build:lib": "node esbuild.config.js",
    "build": "npm run build:clean && npm run build:lib && npm run build:types && npm run docs:build",
    "prepack": "npm run lint && npm run build"
  },
  "peerDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.4.0",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@stylistic/eslint-plugin": "^4.2.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^4.3.0",
    "eslint-plugin-import-x": "^4.10.0",
    "eslint-plugin-prettier": "^5.2.0",
    "eslint-plugin-vue": "^10.0.0",
    "postcss": "^8.5.0",
    "postcss-html": "^1.8.0",
    "postcss-scss": "^4.0.0",
    "prettier": "^3.5.3",
    "stylelint": "^16.17.0",
    "stylelint-config-css-modules": "^4.4.0",
    "stylelint-config-recess-order": "^6.0.0",
    "stylelint-config-recommended": "^15.0.0",
    "stylelint-config-recommended-vue": "^1.6.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0",
    "vue-eslint-parser": "^10.1.0"
  },
  "peerDependenciesMeta": {
    "@graphql-eslint/eslint-plugin": {
      "optional": true
    },
    "eslint-plugin-vue": {
      "optional": true
    },
    "stylelint": {
      "optional": true
    },
    "stylelint-config-css-modules": {
      "optional": true
    },
    "stylelint-config-recess-order": {
      "optional": true
    },
    "stylelint-config-recommended": {
      "optional": true
    },
    "stylelint-config-recommended-vue": {
      "optional": true
    },
    "stylelint-config-standard-scss": {
      "optional": true
    },
    "postcss": {
      "optional": true
    },
    "postcss-html": {
      "optional": true
    },
    "postcss-scss": {
      "optional": true
    },
    "vue-eslint-parser": {
      "optional": true
    }
  },
  "dependencies": {
    "globals": "^16.0.0"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.4.0",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@stylistic/eslint-plugin": "^4.2.0",
    "@types/node": "22.13.14",
    "esbuild": "^0.25.10",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^4.3.0",
    "eslint-plugin-import-x": "^4.10.0",
    "eslint-plugin-prettier": "^5.2.0",
    "eslint-plugin-vue": "^10.0.0",
    "fast-glob": "^3.3.3",
    "husky": "8.0.3",
    "jiti": "2.5.1",
    "postcss": "^8.5.0",
    "postcss-html": "^1.8.0",
    "postcss-scss": "^4.0.0",
    "prettier": "^3.5.3",
    "stylelint": "^16.17.0",
    "stylelint-config-css-modules": "^4.4.0",
    "stylelint-config-recess-order": "^6.0.0",
    "stylelint-config-recommended": "^15.0.0",
    "stylelint-config-recommended-vue": "^1.6.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0",
    "vitepress": "^1.6.4",
    "vue-eslint-parser": "^10.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "prettier": "./src/prettier/index.js"
}