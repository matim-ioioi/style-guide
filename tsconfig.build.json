{
  "extends": ["./tsconfig.json"],
  "compilerOptions": {
    "baseUrl": ".",
    "typeRoots": ["node_modules/@types"],
    "types": ["node"],
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "composite": false,
    "outDir": "dist/eslint",
  },
  "include": ["src/eslint/**/*.ts"],
  "exclude": ["node_modules"]
}
